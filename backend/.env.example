# ── IntellMeet Backend Environment Configurations ─────────────────────────────
# Copy this file to '.env' and fill in the values below.
# IMPORTANT: Never commit '.env' files to git!

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development # development or production

# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/intellmeet?appName=IntellMeet

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# Access token (15-min expiry) & Refresh token (7-day expiry)
# Generate a strong 64-byte random hex secret using the command:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Keep these values secure and private!
JWT_SECRET=your_64_byte_random_hex_here
JWT_REFRESH_SECRET=your_other_64_byte_random_hex_here

# ── CORS (Socket.io + Express CORS) ──────────────────────────────────────────
# Set this to the production frontend Vercel URL (with no trailing slash).
# In development, local Vite server origins (e.g. localhost:5173) are allowed automatically.
CLIENT_URL=https://intell-meet-ten.vercel.app

# ── AI ───────────────────────────────────────────────────────────────────────
# Keep your OpenAI API Key secure on the backend ONLY. Never expose it to the frontend!
OPENAI_API_KEY=your_openai_api_key_here
