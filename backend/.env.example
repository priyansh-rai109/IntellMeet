# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/intellmeet?appName=IntellMeet

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# ── CORS (Socket.io + Express) ────────────────────────────────────────────────
# Set this to your Vercel deployment URL (no trailing slash).
# This is the canonical origin checked by both Express CORS and Socket.io.
CLIENT_URL=https://your-app.vercel.app

# ── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
