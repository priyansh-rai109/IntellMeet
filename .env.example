# ── IntellMeet Frontend Environment Configurations ────────────────────────────
# Copy this file to '.env' in the project root.
#
# SECURITY WARNING: Only include public, non-sensitive configuration keys.
# DO NOT place API keys, JWT secrets, database connection strings, or any other credentials here.
# OpenAI calls and JWT generation/verification must remain entirely on the backend.

# Set this to your live backend Render deployment URL (no trailing slash).
# In local development, the app automatically falls back to 'http://localhost:5000'.
VITE_BACKEND_URL=https://your-backend-api.onrender.com
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
